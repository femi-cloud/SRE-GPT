# .env.example
# Google Cloud
GCP_PROJECT_ID=mon-projet-hackathon
GCP_REGION=us-central1
CLOUD_RUN_SERVICE_NAME=sre-gpt-api

# Dynatrace (Required)
DT_ENVIRONMENT_URL=https://xxxxx.live.dynatrace.com
DT_API_TOKEN=dt0c01.xxxxx

# Gemini API (Google Cloud Agent Builder)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AI Studio automatically injects this at runtime from user secrets.
# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Agent Thresholds
ALERT_LATENCY_MS=1000
ALERT_ERROR_RATE=0.1
